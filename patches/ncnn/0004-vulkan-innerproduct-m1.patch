diff --git a/tests/test_innerproduct.cpp b/tests/test_innerproduct.cpp
index 66a2fbdd..3674afce 100644
--- a/tests/test_innerproduct.cpp
+++ b/tests/test_innerproduct.cpp
@@ -3,6 +3,118 @@
 
 #include "testutil.h"
 
+#if NCNN_VULKAN
+#include "gpu.h"
+#include "vulkan/innerproduct_vulkan.h"
+#endif
+
+#if NCNN_VULKAN
+static int test_innerproduct_m1_uses_vector_pipeline()
+{
+    if (ncnn::get_gpu_count() == 0)
+        return 0;
+
+    const int input_size = 128;
+    const int output_size = 16;
+    ncnn::InnerProduct_vulkan op;
+    op.vkdev = ncnn::get_gpu_device(0);
+
+    ncnn::ParamDict pd;
+    pd.set(0, output_size);
+    pd.set(1, 0);
+    pd.set(2, input_size * output_size);
+    if (op.load_param(pd) != 0)
+        return -1;
+    op.weight_data = RandomMat(input_size * output_size);
+    op.bottom_shapes.resize(1);
+    op.bottom_shapes[0] = ncnn::Mat(input_size, 1, (void*)0);
+    op.top_shapes.resize(1);
+    op.top_shapes[0] = ncnn::Mat(output_size, 1, (void*)0);
+
+    ncnn::Option opt;
+    opt.use_vulkan_compute = true;
+    opt.use_packing_layout = true;
+    opt.use_fp16_packed = false;
+    opt.use_fp16_storage = false;
+    opt.use_fp16_arithmetic = false;
+    if (op.create_pipeline(opt) != 0)
+        return -1;
+
+    const bool uses_vector_pipeline = op.pipeline_innerproduct != 0 ||
+                                      op.pipeline_innerproduct_sum8 != 0;
+    const bool uses_gemm_pipeline = op.pipeline_innerproduct_gemm != 0;
+    op.destroy_pipeline(opt);
+    if (!uses_vector_pipeline || uses_gemm_pipeline)
+    {
+        fprintf(stderr,
+                "InnerProduct Vulkan M=1 must use vector pipeline "
+                "(vector=%d gemm=%d)\n",
+                uses_vector_pipeline,
+                uses_gemm_pipeline);
+        return -1;
+    }
+    return 0;
+}
+
+#if NCNN_INT8
+static int test_innerproduct_m1_int8_uses_vector_pipeline()
+{
+    if (ncnn::get_gpu_count() == 0)
+        return 0;
+
+    const int input_size = 128;
+    const int output_size = 16;
+    ncnn::InnerProduct_vulkan op;
+    op.vkdev = ncnn::get_gpu_device(0);
+
+    ncnn::ParamDict pd;
+    pd.set(0, output_size);
+    pd.set(1, 0);
+    pd.set(2, input_size * output_size);
+    pd.set(8, 1);
+    if (op.load_param(pd) != 0)
+        return -1;
+    op.weight_data.create(input_size * output_size, (size_t)1u);
+    memset(op.weight_data.data, 1, input_size * output_size);
+    op.weight_data_int8_scales.create(output_size);
+    op.weight_data_int8_scales.fill(1.f);
+    op.bottom_blob_int8_scales.create(1);
+    op.bottom_blob_int8_scales.fill(1.f);
+    op.bottom_shapes.resize(1);
+    op.bottom_shapes[0] = ncnn::Mat(input_size, 1, (void*)0);
+    op.top_shapes.resize(1);
+    op.top_shapes[0] = ncnn::Mat(output_size, 1, (void*)0);
+
+    ncnn::Option opt;
+    opt.use_vulkan_compute = true;
+    opt.use_packing_layout = true;
+    opt.use_int8_inference = true;
+    opt.use_int8_storage = true;
+    opt.use_int8_packed = true;
+    opt.use_fp16_packed = false;
+    opt.use_fp16_storage = false;
+    opt.use_fp16_arithmetic = false;
+    if (op.create_pipeline(opt) != 0)
+        return -1;
+
+    const bool uses_vector_pipeline = op.pipeline_innerproduct_int8 != 0 ||
+                                      op.pipeline_innerproduct_sum8_int8 != 0;
+    const bool uses_gemm_pipeline = op.pipeline_innerproduct_gemm_int8 != 0;
+    op.destroy_pipeline(opt);
+    if (!uses_vector_pipeline || uses_gemm_pipeline)
+    {
+        fprintf(stderr,
+                "INT8 InnerProduct Vulkan M=1 must use vector pipeline "
+                "(vector=%d gemm=%d)\n",
+                uses_vector_pipeline,
+                uses_gemm_pipeline);
+        return -1;
+    }
+    return 0;
+}
+#endif // NCNN_INT8
+#endif
