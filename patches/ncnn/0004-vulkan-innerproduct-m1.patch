 namespace ncnn {
 
+static void innerproduct_vector_output_to_single_row(VkMat& blob, int num_output)
+{
+    const size_t scalar_elemsize = blob.elemsize / blob.elempack;
+    blob.dims = 2;
+    blob.w = num_output;
+    blob.h = 1;
+    blob.d = 1;
+    blob.c = 1;
+    blob.cstep = alignSize((size_t)num_output * scalar_elemsize, 16) / scalar_elemsize;
+    blob.elemsize = scalar_elemsize;
+    blob.elempack = 1;
+}
+
 InnerProduct_vulkan::InnerProduct_vulkan()
 {
     support_vulkan = true;
