         return forward_bf16s(bottom_blobs, top_blobs, opt);
 #endif

+    if (full_cache)
+        return RotaryEmbed::forward(bottom_blobs, top_blobs, opt);
+
     const Mat& bottom_blob = bottom_blobs[0];
     const Mat& cos_cache = bottom_blobs[1];
     const Mat& sin_cache = bottom_blobs[2];
diff --git a/tests/test_rotaryembed.cpp b/tests/test_rotaryembed.cpp
index 1d79c4b0..be873d80 100644
--- a/tests/test_rotaryembed.cpp
+++ b/tests/test_rotaryembed.cpp
@@ -31,9 +31,26 @@ static int test_rotaryembed(const ncnn::Mat& a, int interleaved)
     return ret;
 }

+static int test_rotaryembed_full_cache()
+{
+    const int embed_dim = 32;
+    const int seqlen = 7;
+    const int num_heads = 3;
+    ncnn::Mat input = RandomMat(embed_dim, seqlen, num_heads);
+    ncnn::Mat cos_cache = RandomMat(embed_dim, seqlen);
+    ncnn::Mat sin_cache = RandomMat(embed_dim, seqlen);
+
+    ncnn::ParamDict pd;
+    pd.set(0, 0);
+    pd.set(1, 1);
+    std::vector<ncnn::Mat> as{input, cos_cache, sin_cache};
+    return test_layer("RotaryEmbed", pd, std::vector<ncnn::Mat>(), as, 1);
+}
+
 static int test_rotaryembed_0()
 {
     return 0
+           || test_rotaryembed_full_cache()
            || test_rotaryembed(RandomMat(32, 66, 8), 0)
            || test_rotaryembed(RandomMat(26, 64, 8), 1)
            || test_rotaryembed(RandomMat(64, 28, 12), 0)
