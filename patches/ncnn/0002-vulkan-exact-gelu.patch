From: HunyuanOCR-ncnn contributors
Subject: [PATCH 2/2] Vulkan exact GELU for HunyuanOCR vision
Upstream: https://github.com/Tencent/ncnn
License: BSD 3-Clause
Local-Note: Preserve fast_gelu behavior and add the fp32 erf-approximation path
 used by the CPU reference, with an ncnn Vulkan regression test. The public
 capability macro identifies the complete project-maintained Vulkan patchset.

diff --git a/src/layer/vulkan/gelu_vulkan.cpp b/src/layer/vulkan/gelu_vulkan.cpp
index c7b55b91..4bd0cc66 100644
--- a/src/layer/vulkan/gelu_vulkan.cpp
+++ b/src/layer/vulkan/gelu_vulkan.cpp
@@ -19,8 +19,9 @@ int GELU_vulkan::create_pipeline(const Option& opt)
 {
     const Mat& shape = top_shapes.empty() ? Mat() : top_shapes[0];
 
-    std::vector<vk_specialization_type> specializations(1);
+    std::vector<vk_specialization_type> specializations(2);
     specializations[0].u32 = shape.total() * shape.elempack / 4;
+    specializations[1].i = fast_gelu;
 
     const int local_size_x = vkdev->info.subgroup_size();
 
diff --git a/src/layer/vulkan/shader/gelu.comp b/src/layer/vulkan/shader/gelu.comp
index 3c657518..7bfaaf26 100644
--- a/src/layer/vulkan/shader/gelu.comp
+++ b/src/layer/vulkan/shader/gelu.comp
@@ -5,6 +5,7 @@
 
 #define shape_constant_id_offset 0
 layout(constant_id = 0) const uint n = 0;
+layout(constant_id = 1) const int fast_gelu = 0;
 
 layout(binding = 0) buffer bottom_top_blob { sfpvec4 bottom_top_blob_data[]; };
 
@@ -13,6 +14,21 @@ layout(push_constant) uniform parameter
     uint n;
 } p;
 
+afpvec4 erf_approx(afpvec4 x)
+{
+    afpvec4 a1 = afpvec4(0.254829592f);
+    afpvec4 a2 = afpvec4(-0.284496736f);
+    afpvec4 a3 = afpvec4(1.421413741f);
+    afpvec4 a4 = afpvec4(-1.453152027f);
+    afpvec4 a5 = afpvec4(1.061405429f);
+    afpvec4 coefficient = afpvec4(0.3275911f);
+    afpvec4 sign_x = sign(x);
+    afpvec4 abs_x = abs(x);
+    afpvec4 t = afpvec4(1.0f) / (afpvec4(1.0f) + coefficient * abs_x);
+    afpvec4 y = afpvec4(1.0f) - (((((a5 * t + a4) * t) + a3) * t + a2) * t + a1) * t * exp(-abs_x * abs_x);
+    return sign_x * y;
+}
+
 void main()
 {
     uint gi = gl_GlobalInvocationID.x;
@@ -22,13 +38,21 @@ void main()
 
     afpvec4 v = buffer_ld4(bottom_top_blob_data, gi);
 
-    // y = 0.5x * (1 + tanh(sqrt(2/Pi) * (x + 0.044715x^3)))
-
+    if (fast_gelu == 1)
+    {
+        // y = 0.5x * (1 + tanh(sqrt(2/Pi) * (x + 0.044715x^3)))
 #if NCNN_moltenvk
-    v = afpvec4(0.5f) * v * (afpvec4(1.0f) + afpvec4(tanh(vec4(afpvec4(0.79788452f) * (v + afpvec4(0.044715f) * v * v * v)))));
+        v = afpvec4(0.5f) * v * (afpvec4(1.0f) + afpvec4(tanh(vec4(afpvec4(0.79788452f) * (v + afpvec4(0.044715f) * v * v * v)))));
 #else
-    v = afpvec4(0.5f) * v * (afpvec4(1.0f) + tanh(afpvec4(0.79788452f) * (v + afpvec4(0.044715f) * v * v * v)));
+        v = afpvec4(0.5f) * v * (afpvec4(1.0f) + tanh(afpvec4(0.79788452f) * (v + afpvec4(0.044715f) * v * v * v)));
 #endif
+    }
+    else
+    {
+        // y = 0.5x * erfc(-x / sqrt(2))
+        v = afpvec4(0.5f) * v *
+            (afpvec4(1.0f) + erf_approx(afpvec4(0.70710678f) * v));
+    }
 
     buffer_st4(bottom_top_blob_data, gi, v);
 }
