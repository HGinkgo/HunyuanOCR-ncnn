 }
 
+static int test_gelu_exact_vulkan_fp32()
+{
+    ncnn::ParamDict pd;
+    pd.set(0, 0);
+
+    std::vector<ncnn::Mat> weights;
+    ncnn::Option opt;
+    opt.use_packing_layout = true;
+    opt.use_fp16_packed = false;
+    opt.use_fp16_storage = false;
+    opt.use_fp16_arithmetic = false;
+    opt.use_bf16_packed = false;
+    opt.use_bf16_storage = false;
+
+    const ncnn::Mat input = RandomMat(4304, 17);
+    return test_layer(ncnn::layer_to_index("GELU"), pd, weights, opt, input, ncnn::Mat(), 0.00001f, 0);
+}
+
 static int test_gelu_0()
 {
     return 0
@@ -76,6 +94,7 @@ int main()
     SRAND(7767517);
 
     return 0
+           || test_gelu_exact_vulkan_fp32()
            || test_gelu_0()
            || test_gelu_1()
            || test_gelu_2()

