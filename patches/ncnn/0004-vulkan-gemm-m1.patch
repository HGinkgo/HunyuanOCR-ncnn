From: HunyuanOCR-ncnn contributors
Subject: [PATCH 4/4] Vulkan Gemm M=1 vector dispatch
Upstream: https://github.com/Tencent/ncnn
License: BSD 3-Clause
Local-Note: Reuse the existing InnerProduct vector shaders for compatible
 constant-weight FP32 Gemm layers when the runtime input has M=1, while
 preserving the original M>1 Gemm pipeline. The two paths share the uploaded
 Gemm weights, so models require no graph rewrite or duplicate weight buffer.
diff --git a/src/layer/vulkan/gemm_vulkan.cpp b/src/layer/vulkan/gemm_vulkan.cpp
index b2e57c2d..9086b9fb 100644
--- a/src/layer/vulkan/gemm_vulkan.cpp
+++ b/src/layer/vulkan/gemm_vulkan.cpp
@@ -26,6 +26,8 @@ Gemm_vulkan::Gemm_vulkan()
     support_vulkan_any_packing = true;
 
     pipeline_gemm = 0;
+    pipeline_gemv_sum8 = 0;
+    pipeline_gemv_reduce_sum8 = 0;
 #if NCNN_INT8
     pipeline_gemm_quantize_A_int8 = 0;
     pipeline_gemm_quantize_B_absmax_int8 = 0;
@@ -610,6 +612,39 @@ int Gemm_vulkan::create_pipeline(const Option& opt)
         pipeline_gemm->create(LayerShaderType::gemm, opt, specializations);
     }
 
+    const bool gemv_compatible = constantA == 0 && constantB == 1 && constantC == 1 &&
+                                 transA == 0 && transB == 1 && alpha == 1.f &&
+                                 constant_broadcast_type_C == -1 && output_N1M == 0 &&
+                                 output_elempack == 0 && output_elemtype == 0 &&
+                                 output_transpose == 0 && !use_cooperative_matrix &&
+                                 B_data_packed.elempack == 1 && constantK >= 32;
+    if (gemv_compatible)
+    {
+        const int outw_sum8 = (constantK + 7) / 8;
+
+        std::vector<vk_specialization_type> specializations(3);
+        specializations[0].i = constantK;
+        specializations[1].i = outw_sum8;
+        specializations[2].i = constantN;
+
+        pipeline_gemv_sum8 = new Pipeline(vkdev);
+        pipeline_gemv_sum8->set_local_size_xyz(8, std::min(8, constantN), 1);
+        pipeline_gemv_sum8->create(LayerShaderType::innerproduct_sum8, opt, specializations);
+
+        std::vector<vk_specialization_type> reduce_specializations(7);
+        reduce_specializations[0].i = 0;
+        reduce_specializations[1].i = 0;
+        reduce_specializations[2].f = 0.f;
+        reduce_specializations[3].f = 0.f;
+        reduce_specializations[4].i = outw_sum8;
+        reduce_specializations[5].i = constantN;
+        reduce_specializations[6].i = constantN;
+
+        pipeline_gemv_reduce_sum8 = new Pipeline(vkdev);
+        pipeline_gemv_reduce_sum8->set_local_size_xyz(std::min(64, constantN), 1, 1);
+        pipeline_gemv_reduce_sum8->create(LayerShaderType::innerproduct_reduce_sum8, opt, reduce_specializations);
+    }
+
     if (opt.lightmode)
     {
         A_data.release();
@@ -625,6 +660,11 @@ int Gemm_vulkan::destroy_pipeline(const Option& /*opt*/)
     delete pipeline_gemm;
     pipeline_gemm = 0;
 
+    delete pipeline_gemv_sum8;
+    delete pipeline_gemv_reduce_sum8;
+    pipeline_gemv_sum8 = 0;
+    pipeline_gemv_reduce_sum8 = 0;
+
 #if NCNN_INT8
     delete pipeline_gemm_quantize_A_int8;
     pipeline_gemm_quantize_A_int8 = 0;
@@ -825,6 +865,44 @@ int Gemm_vulkan::forward(const std::vector<VkMat>& bottom_blobs, std::vector<VkM
     if (top_blob.empty())
         return -100;
 
+    if (pipeline_gemv_sum8 && M == 1 && A_elempack == 1 && B_elempack == 1 && out_elempack == 1)
+    {
+        VkMat top_blob_sum8;
+        top_blob_sum8.create((K + 7) / 8, N, elemsize, 1, opt.blob_vkallocator);
+        if (top_blob_sum8.empty())
+            return -100;
+
+        {
+            std::vector<VkMat> bindings(3);
+            bindings[0] = A;
+            bindings[1] = top_blob_sum8;
+            bindings[2] = B;
+
+            std::vector<vk_constant_type> constants(3);
+            constants[0].i = K;
+            constants[1].i = top_blob_sum8.w;
+            constants[2].i = top_blob_sum8.h;
+
+            cmd.record_pipeline(pipeline_gemv_sum8, bindings, constants, top_blob_sum8);
+        }
+
+        {
+            std::vector<VkMat> bindings(3);
+            bindings[0] = top_blob_sum8;
+            bindings[1] = top_blob;
+            bindings[2] = C;
+
+            std::vector<vk_constant_type> constants(3);
+            constants[0].i = top_blob_sum8.w;
+            constants[1].i = top_blob_sum8.h;
+            constants[2].i = N;
+
+            cmd.record_pipeline(pipeline_gemv_reduce_sum8, bindings, constants, top_blob);
+        }
+
+        return 0;
+    }
+
     if (use_cooperative_matrix)
     {
         std::vector<VkMat> bindings(5);
diff --git a/src/layer/vulkan/gemm_vulkan.h b/src/layer/vulkan/gemm_vulkan.h
