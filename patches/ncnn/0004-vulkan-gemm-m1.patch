--- a/src/layer/vulkan/gemm_vulkan.h
+++ b/src/layer/vulkan/gemm_vulkan.h
@@ -39,6 +39,8 @@ public:
     VkMat C_data_gpu;
 
     Pipeline* pipeline_gemm;
+    Pipeline* pipeline_gemv_sum8;
+    Pipeline* pipeline_gemv_reduce_sum8;
 
     // subgroup
     bool use_subgroup_ops;
diff --git a/tests/test_gemm_vulkan_m1.cpp b/tests/test_gemm_vulkan_m1.cpp
new file mode 100644
index 00000000..f0912943
--- /dev/null
+++ b/tests/test_gemm_vulkan_m1.cpp
@@ -0,0 +1,73 @@
+// Copyright 2026 Tencent
+// SPDX-License-Identifier: BSD-3-Clause
+
+#include "testutil.h"
+
+#if NCNN_VULKAN
+#include "gpu.h"
+#include "vulkan/gemm_vulkan.h"
+
+static int test_gemm_m1_creates_vector_and_matrix_pipelines()
+{
+    if (ncnn::get_gpu_count() == 0)
+        return 0;
+
+    const int input_size = 128;
+    const int output_size = 64;
+
+    ncnn::Gemm_vulkan op;
+    op.vkdev = ncnn::get_gpu_device(0);
+
+    ncnn::ParamDict pd;
+    pd.set(0, 1.f); // alpha
+    pd.set(1, 1.f); // beta
+    pd.set(2, 0);   // transA
+    pd.set(3, 1);   // transB
+    pd.set(4, 0);   // constantA
+    pd.set(5, 1);   // constantB
+    pd.set(6, 1);   // constantC
+    pd.set(8, output_size);
+    pd.set(9, input_size);
+    pd.set(10, -1); // no C data
+    if (op.load_param(pd) != 0)
+        return -1;
+
+    op.B_data = RandomMat(input_size, output_size);
+
+    ncnn::Option opt;
+    opt.use_vulkan_compute = true;
+    opt.use_packing_layout = true;
+    opt.use_fp16_packed = false;
+    opt.use_fp16_storage = false;
+    opt.use_fp16_arithmetic = false;
+    opt.use_bf16_packed = false;
+    opt.use_bf16_storage = false;
+
+    if (op.create_pipeline(opt) != 0)
+        return -1;
+
+    const bool keeps_matrix_pipeline = op.pipeline_gemm != 0;
+    const bool creates_vector_pipeline = op.pipeline_gemv_sum8 != 0 &&
+                                         op.pipeline_gemv_reduce_sum8 != 0;
+    op.destroy_pipeline(opt);
+
+    if (!keeps_matrix_pipeline || !creates_vector_pipeline)
+    {
+        fprintf(stderr, "Gemm must keep M>1 pipeline and create M=1 vector pipelines\n");
+        return -1;
+    }
+
+    return 0;
+}
+#endif
+
+int main()
+{
+    SRAND(7767517);
+
+#if NCNN_VULKAN
+    return test_gemm_m1_creates_vector_and_matrix_pipelines();
+#else
+    return 0;
+#endif
+}
